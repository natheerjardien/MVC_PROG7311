@model prjHealthCareSystem.Models.InsurancePolicy

@{
    ViewData["Title"] = "Delete Insurance Policy";
}

<h2>Delete Insurance Policy</h2>
<h4 class="text-danger mt-3">Are you sure you want to delete this policy?</h4>
<hr />

<div class="card mb-4 shadow-sm" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Policy Name</dt>
            <dd class="col-sm-8 fw-bold">@Model.PolicyName</dd>

            <dt class="col-sm-4">Patient Name</dt>
            <dd class="col-sm-8">@Model.Patient?.Name</dd>

            <dt class="col-sm-4">Start Date</dt>
            <dd class="col-sm-8">@Model.StartDate.ToShortDateString()</dd>

            <dt class="col-sm-4">End Date</dt>
            <dd class="col-sm-8">@Model.EndDate.ToShortDateString()</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                <span class="badge bg-secondary">@Model.Status</span>
            </dd>

            <dt class="col-sm-4">Service Level</dt>
            <dd class="col-sm-8">@Model.ServiceLevel</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Confirm Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>